# Copie ce fichier en .env.local et remplis avec tes vraies clés Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TON_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ta_clé_anon_supabase

# Service key (jamais exposée côté client - Supabase > Settings > API > service_role key)
SUPABASE_SERVICE_KEY=ta_service_role_key_supabase
